{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "allowJs": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@slidev/client": ["./types/slidev-client.d.ts"]
    }
  },
  "include": ["lib", "tests", "setup", "types", "components/**/*.vue", "global-bottom.vue"]
}
